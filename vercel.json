{
  "rewrites": [
    { "source": "/api/accounts/:path*", "destination": "https://finly.uyqidir.uz/api/accounts/:path*" },
    { "source": "/api/expenses/:path*", "destination": "https://finly.uyqidir.uz/api/expenses/:path*" },
    { "source": "/api/debts/:path*",    "destination": "https://finly.uyqidir.uz/api/debts/:path*" },
    { "source": "/api/transfers/:path*", "destination": "https://finly.uyqidir.uz/api/transfers/:path*" },
    { "source": "/api/income/:path*",    "destination": "https://finly.uyqidir.uz/api/incomes/:path*" },
    { "source": "/api/budget/categories/:path*", "destination": "https://finly.uyqidir.uz/api/budgets/categories/:path*" },
    { "source": "/api/budget/:path*",    "destination": "https://finly.uyqidir.uz/api/budgets/:path*" },
    { "source": "/api/statistics/:path*", "destination": "https://finly.uyqidir.uz/api/statistics/:path*" },
    { "source": "/api/auth/:path*",      "destination": "https://finly.uyqidir.uz/api/auth/:path*" },
    { "source": "/api/:path*",           "destination": "https://finly.uyqidir.uz/api/:path*" },
    { "source": "/:path*",               "destination": "/index.html" }
  ]
}
